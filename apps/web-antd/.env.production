VITE_BASE=/

# Admin backend base URL — all requests go to /admin/api/* on this host (tiktok-admin Flask app)
VITE_GLOB_API_URL=https://tiktokio.lol

# Compression
VITE_COMPRESS=gzip

# PWA disabled
VITE_PWA=false

# History mode for clean URLs (server must fallback to index.html for all routes)
VITE_ROUTER_HISTORY=history

# Global loading spinner
VITE_INJECT_APP_LOADING=true

# Generate dist.zip on build
VITE_ARCHIVER=true
